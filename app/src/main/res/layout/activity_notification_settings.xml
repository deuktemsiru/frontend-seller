<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/white">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="20sp"
            android:textColor="@color/text"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="알림 설정"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium" />

        <View android:layout_width="40dp" android:layout_height="40dp" />

    </LinearLayout>

    <!-- 주문 알림 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="주문 알림"
        android:textSize="12sp"
        android:textColor="@color/text_sub"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_white"
        android:layout_marginHorizontal="16dp">

        <!-- 신규 주문 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="신규 주문 알림"
                    android:textSize="14sp"
                    android:textColor="@color/text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새 주문이 들어오면 알림을 받아요"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_new_order"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface"
            android:layout_marginHorizontal="16dp" />

        <!-- 픽업 완료 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="픽업 완료 알림"
                    android:textSize="14sp"
                    android:textColor="@color/text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="고객이 픽업을 완료하면 알림을 받아요"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_pickup_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface"
            android:layout_marginHorizontal="16dp" />

        <!-- 판매 완료 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="판매 완료 알림"
                    android:textSize="14sp"
                    android:textColor="@color/text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모든 상품이 판매 완료되면 알림을 받아요"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switch_sale_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- FCM 안내 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_insight_box"
        android:padding="14dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💡 앱이 백그라운드 상태일 때 실시간 푸시 알림을 받으려면 기기 알림 권한을 허용해주세요."
            android:textSize="12sp"
            android:textColor="@color/text_sub" />

    </LinearLayout>

</LinearLayout>
