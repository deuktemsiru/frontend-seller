<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@color/white">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="매출 분석"
            android:textSize="18sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Period Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/btnPrev"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="◀"
                    android:textSize="13sp"
                    android:textColor="@color/text_sub" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_white"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tab_weekly"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="주간"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_button_primary" />

                    <TextView
                        android:id="@+id/tab_monthly"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="월간"
                        android:textSize="13sp"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tab_yearly"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="연간"
                        android:textSize="13sp"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnNext"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="▶"
                    android:textSize="13sp"
                    android:textColor="@color/text_sub" />

            </LinearLayout>

            <!-- Period Label -->
            <TextView
                android:id="@+id/tvPeriodRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_sub"
                android:layout_marginBottom="14dp" />

            <!-- Sales Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSalesTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="주간 매출"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub" />

                    <TextView
                        android:id="@+id/tvLoadingIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="로딩 중..."
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvTotalSales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="24sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />

                <com.example.deuktemsiru_seller.ui.sales.BarChartView
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <!-- Environment Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_gradient_success_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="🌍"
                    android:textSize="24sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="환경 기여"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvWasteCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="절감 폐기 --개"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvCo2Amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="탄소 --kg 절감"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Top Menus Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="잘 팔리는 메뉴 TOP 3"
                android:textSize="15sp"
                android:textColor="@color/text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <!-- Top Menus Container (dynamic) -->
            <LinearLayout
                android:id="@+id/containerTopMenus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp" />

            <!-- Insight Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_insight_box"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvInsight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 데이터를 불러오는 중이에요..."
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
