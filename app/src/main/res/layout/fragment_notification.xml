<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@color/white">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="단골 알림 발송"
            android:textSize="18sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 1/3 사용"
            android:textSize="12sp"
            android:textColor="@color/text_sub"
            android:background="@drawable/bg_rounded_muted"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Target Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="발송 대상"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Regular customers (selected) -->
                <LinearLayout
                    android:id="@+id/option_regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_primary_border"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ 단골 손님 (38명)"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_rounded_primary" />

                </LinearLayout>

                <!-- Nearby customers -->
                <LinearLayout
                    android:id="@+id/option_nearby"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 근처 손님"
                        android:textSize="14sp"
                        android:textColor="@color/text_sub" />

                </LinearLayout>

            </LinearLayout>

            <!-- Message Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="알림 메시지"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_char_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="23/40"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

                <EditText
                    android:id="@+id/et_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:gravity="top"
                    android:text="오늘 마감 특가! 크루아상 모음 50% 할인해요 🥐"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:background="@drawable/bg_rounded_muted"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:maxLength="40"
                    android:layout_marginBottom="12dp" />

                <!-- Quick phrase chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="마감 특가!"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="오늘만 할인"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="선착순!"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Preview -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="미리보기"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Phone notification mockup -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_notification_preview"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="🥐"
                        android:textSize="22sp"
                        android:background="@drawable/bg_rounded_primary"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="오늘만이"
                            android:textSize="12sp"
                            android:textColor="#AAFFFFFF"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_preview_store_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_preview_message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="오늘 마감 특가! 크루아상 모음 50% 할인해요 🥐"
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지금"
                        android:textSize="11sp"
                        android:textColor="#66FFFFFF" />

                </LinearLayout>

            </LinearLayout>

            <!-- Expected reach -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rounded_success_light"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="18sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="예상 도달"
                        android:textSize="12sp"
                        android:textColor="@color/success"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="38명 중 22명이 알림을 열어볼 거예요"
                        android:textSize="13sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Insight Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_insight_box"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 마감 30분 전 발송 시 응답률 2배! 지금이 적기예요."
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark" />

            </LinearLayout>

            <!-- History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="발송 내역"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/notification_history_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Fixed CTA Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📨  38명에게 지금 보내기"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_primary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
