<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@color/white">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="단골 알림 발송"
            android:textSize="18sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_rounded_warning"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/tv_send_count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 발송 횟수"
                android:textSize="10sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_send_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 3"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Target Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="발송 대상"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/option_regular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_primary_border"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ 단골 손님 (38명)"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:id="@+id/indicator_regular"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_rounded_primary" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/option_nearby"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_white"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 근처 손님"
                        android:textSize="14sp"
                        android:textColor="@color/text_sub" />

                    <View
                        android:id="@+id/indicator_nearby"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_rounded_muted" />

                </LinearLayout>

                <!-- Nearby radius selector + map (초기 GONE) -->
                <LinearLayout
                    android:id="@+id/layout_nearby_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="반경 설정"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/btn_radius_3"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:gravity="center"
                            android:text="3km"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_button_primary"
                            android:fontFamily="sans-serif-medium"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_radius_5"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="6dp"
                            android:gravity="center"
                            android:text="5km"
                            android:textSize="13sp"
                            android:textColor="@color/text_sub"
                            android:background="@drawable/bg_rounded_muted"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_radius_10"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:text="10km"
                            android:textSize="13sp"
                            android:textColor="@color/text_sub"
                            android:background="@drawable/bg_rounded_muted"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Map View -->
                    <com.example.deuktemsiru_seller.ui.notification.RadiusMapView
                        android:id="@+id/radius_map_view"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_nearby_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="반경 3km 내 약 12명"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub" />

                </LinearLayout>

            </LinearLayout>

            <!-- Message Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="알림 메시지"
                        android:textSize="14sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_char_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/40"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted" />

                </LinearLayout>

                <EditText
                    android:id="@+id/et_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:gravity="top"
                    android:hint="알림 메시지를 입력하세요"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:background="@drawable/bg_rounded_muted"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:maxLength="40"
                    android:layout_marginBottom="12dp" />

                <!-- Quick phrase label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="자주 쓰는 문구"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub" />

                    <TextView
                        android:id="@+id/btn_add_phrase"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="+ 추가"
                        android:textSize="11sp"
                        android:textColor="#FFB74D"
                        android:background="@drawable/bg_chip_orange"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Quick phrase chips container -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/phrase_chips_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexDirection="row"
                    app:flexWrap="wrap">

                    <TextView
                        android:id="@+id/chip_phrase_1"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="마감 특가!"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_orange"
                        android:paddingHorizontal="12dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_phrase_2"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="오늘만 할인"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_orange"
                        android:paddingHorizontal="12dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_phrase_3"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="선착순!"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:background="@drawable/bg_chip_orange"
                        android:paddingHorizontal="12dp"
                        android:layout_marginBottom="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                </com.google.android.flexbox.FlexboxLayout>

            </LinearLayout>

            <!-- Preview -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="미리보기"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_notification_preview"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="🥐"
                        android:textSize="22sp"
                        android:background="@drawable/bg_rounded_primary"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="오늘만이"
                            android:textSize="12sp"
                            android:textColor="#AAFFFFFF"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_preview_store_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_preview_message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지금"
                        android:textSize="11sp"
                        android:textColor="#66FFFFFF" />

                </LinearLayout>

            </LinearLayout>

            <!-- History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="발송 내역"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/notification_history_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Fixed CTA Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📨  지금 보내기"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_primary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
