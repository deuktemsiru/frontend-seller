<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이렇게 등록될 예정이에요"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

        <!-- Preview Card - how it'll look to customers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="구매자 앱 미리보기"
                android:textSize="12sp"
                android:textColor="@color/text_sub"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_preview_menu_image"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_rounded_primary_light"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_preview_menu_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="크루아상 모음 박스"
                        android:textSize="15sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_preview_store_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tv_preview_discount_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5,900원"
                            android:textSize="17sp"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tv_preview_discount_rate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" 60%↓"
                            android:textSize="12sp"
                            android:textColor="@color/danger"
                            android:fontFamily="sans-serif-medium" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_preview_quantity_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="잔여 5개 · 픽업 16:30–18:00"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Registration summary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="등록 정보 요약"
                android:textSize="14sp"
                android:textColor="@color/text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="메뉴명" android:textSize="13sp" android:textColor="@color/text_sub" />
                <TextView android:id="@+id/tv_summary_menu_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="크루아상 모음 박스" android:textSize="13sp" android:textColor="@color/text" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="정상가" android:textSize="13sp" android:textColor="@color/text_sub" />
                <TextView android:id="@+id/tv_summary_original_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15,000원" android:textSize="13sp" android:textColor="@color/text" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="마감 할인가" android:textSize="13sp" android:textColor="@color/text_sub" />
                <TextView android:id="@+id/tv_summary_discount_price" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5,900원 (60% 할인)" android:textSize="13sp" android:textColor="@color/primary" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="판매 수량" android:textSize="13sp" android:textColor="@color/text_sub" />
                <TextView android:id="@+id/tv_summary_quantity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5개" android:textSize="13sp" android:textColor="@color/text" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="픽업 시간" android:textSize="13sp" android:textColor="@color/text_sub" />
                <TextView android:id="@+id/tv_summary_pickup_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16:30 – 18:00" android:textSize="13sp" android:textColor="@color/text" android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
