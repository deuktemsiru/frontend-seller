<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="수량과 픽업 시간을 설정하세요"
            android:textSize="16sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp" />

        <!-- Quantity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="판매 수량"
                android:textSize="14sp"
                android:textColor="@color/text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btn_qty_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="−"
                    android:textSize="22sp"
                    android:textColor="@color/text"
                    android:background="@drawable/bg_rounded_muted"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_quantity"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5"
                    android:textSize="24sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/btn_qty_plus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="+"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_rounded_primary"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- Pickup Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="픽업 시간"
                android:textSize="14sp"
                android:textColor="@color/text"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="14dp" />

            <!-- Dual time cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/container_pickup_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_primary_light"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tv_pickup_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="픽업 시작"
                        android:textSize="11sp"
                        android:textColor="@color/text_sub" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16:30"
                        android:textSize="20sp"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_pickup_end"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_primary_light"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_pickup_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="픽업 마감"
                        android:textSize="11sp"
                        android:textColor="@color/text_sub" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:00"
                        android:textSize="20sp"
                        android:textColor="@color/primary_dark"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Quick time chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_30min"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="+30분"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_1hour"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="+1시간"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:background="@drawable/bg_chip_unselected"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_until_close"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="영업종료까지"
                    android:textSize="11sp"
                    android:textColor="@color/text_sub"
                    android:background="@drawable/bg_chip_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
