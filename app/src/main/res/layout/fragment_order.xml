<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@color/white">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="주문 관리"
            android:textSize="18sp"
            android:textColor="@color/text"
            android:fontFamily="sans-serif-medium" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot_online"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실시간 갱신"
            android:textSize="12sp"
            android:textColor="@color/online" />

        <TextView
            android:id="@+id/btn_pickup_verify"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minWidth="80dp"
            android:paddingHorizontal="14dp"
            android:text="픽업 확인"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Status Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="0dp">

        <TextView
            android:id="@+id/tab_new"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_new_order_default"
            android:textSize="13sp"
            android:textColor="@color/primary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tab_preparing"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_preparing_default"
            android:textSize="13sp"
            android:textColor="@color/text_muted" />

        <TextView
            android:id="@+id/tab_pickup"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_pickup_ready_default"
            android:textSize="13sp"
            android:textColor="@color/text_muted" />

        <TextView
            android:id="@+id/tab_done"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_completed_default"
            android:textSize="13sp"
            android:textColor="@color/text_muted" />

    </LinearLayout>

    <!-- Tab Indicator -->
    <View
        android:id="@+id/tab_indicator"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/primary"
        android:layout_marginStart="16dp" />

    <!-- Content ScrollView -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/order_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
