<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="32dp">

    <!-- 앱 로고 / 타이틀 -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="득템시루 사장님"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintBottom_toTopOf="@+id/tvSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마감 할인으로 폐기를 줄이고\n단골을 늘리세요 🍱"
        android:textSize="15sp"
        android:textColor="#666666"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/btnKakaoLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvAppName"
        android:layout_marginBottom="64dp" />

    <!-- 카카오 로그인 버튼 -->
    <Button
        android:id="@+id/btnKakaoLogin"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="카카오로 시작하기"
        android:textSize="16sp"
        android:textColor="#3C1E1E"
        android:textStyle="bold"
        android:backgroundTint="#FEE500"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toTopOf="@+id/btnMockLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- 목 데이터 로그인 버튼 (DEBUG only, gone in release) -->
    <Button
        android:id="@+id/btnMockLogin"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="[DEV] Bakery 목 데이터로 시작"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#888888"
        android:stateListAnimator="@null"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnKakaoLogin"
        android:layout_marginBottom="60dp" />

    <!-- 로딩 인디케이터 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
