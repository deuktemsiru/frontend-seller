<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="32dp">

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="득템시루 사장님"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintBottom_toTopOf="@+id/tvSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="마감 할인으로 폐기를 줄이고\n단골을 늘리세요 🍱"
        android:textSize="15sp"
        android:textColor="#666666"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/layoutDebugForm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvAppName"
        android:layout_marginBottom="40dp" />

    <!-- DEBUG 전용 ID/PW 폼 (코드에서 visibility 제어) -->
    <LinearLayout
        android:id="@+id/layoutDebugForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/btnKakaoLogin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etLoginId"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="아이디"
            android:inputType="text"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_card_white"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="패스워드"
            android:inputType="textPassword"
            android:textSize="15sp"
            android:textColor="#1A1A1A"
            android:textColorHint="#AAAAAA"
            android:background="@drawable/bg_card_white"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:layout_marginTop="10dp"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="로그인"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <Button
        android:id="@+id/btnKakaoLogin"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="카카오로 시작하기"
        android:textSize="16sp"
        android:textColor="#3C1E1E"
        android:textStyle="bold"
        android:backgroundTint="#FEE500"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutDebugForm"
        android:layout_marginBottom="120dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
