<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Selected menu summary -->
        <LinearLayout
            android:id="@+id/card_selected_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_rounded_primary_light"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_selected_emoji"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_selected_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_selected_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub" />

            </LinearLayout>

        </LinearLayout>

        <!-- Discount rate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="할인율"
                android:textSize="13sp"
                android:textColor="@color/text_sub"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/preset_30"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:gravity="center"
                    android:text="30%"
                    android:textSize="13sp"
                    android:background="@drawable/bg_discount_preset_normal"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset_50"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:gravity="center"
                    android:text="50%"
                    android:textSize="13sp"
                    android:background="@drawable/bg_discount_preset_normal"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset_60"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:gravity="center"
                    android:text="60%"
                    android:textSize="13sp"
                    android:background="@drawable/bg_discount_preset_selected"
                    android:textColor="@color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset_70"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:gravity="center"
                    android:text="70%"
                    android:textSize="13sp"
                    android:background="@drawable/bg_discount_preset_normal"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <EditText
                    android:id="@+id/et_discount_rate"
                    android:layout_width="80dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_rounded_muted"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="2"
                    android:singleLine="true"
                    android:textColor="@color/text"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="%  →"
                    android:textSize="14sp"
                    android:textColor="@color/text_sub" />

                <TextView
                    android:id="@+id/tv_discounted_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="—원"
                    android:textSize="18sp"
                    android:textColor="@color/primary_dark"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </LinearLayout>

        <!-- Quantity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="판매 수량"
                android:textSize="13sp"
                android:textColor="@color/text_sub"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_qty_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_rounded_muted"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"
                    android:text="−"
                    android:textSize="18sp"
                    android:textColor="@color/text" />

                <TextView
                    android:id="@+id/tv_quantity"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5"
                    android:textSize="20sp"
                    android:textColor="@color/text"
                    android:fontFamily="sans-serif-medium" />

                <Button
                    android:id="@+id/btn_qty_plus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_rounded_muted"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null"
                    android:text="+"
                    android:textSize="18sp"
                    android:textColor="@color/text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="개"
                    android:textSize="14sp"
                    android:textColor="@color/text_sub" />

            </LinearLayout>

        </LinearLayout>

        <!-- Pickup time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="픽업 시간"
                android:textSize="13sp"
                android:textColor="@color/text_sub"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/container_pickup_start"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_rounded_muted"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_pickup_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16:30"
                        android:textSize="16sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:text="~"
                    android:textSize="16sp"
                    android:textColor="@color/text_sub" />

                <LinearLayout
                    android:id="@+id/container_pickup_end"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_rounded_muted"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tv_pickup_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:00"
                        android:textSize="16sp"
                        android:textColor="@color/text"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/chip_30min"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="+30분"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_1hour"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="+1시간"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_until_close"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="영업종료까지"
                    android:textSize="12sp"
                    android:textColor="@color/text_sub"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
